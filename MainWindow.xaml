<Window x:Class="Ejercicio1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ejercicio1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="1100">
    <Grid Margin="10,10,-88,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="977*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="44">
            <StackPanel Margin="5">
                <TextBlock Text="Producto"/>
                <TextBox x:Name="txtProducto" Width="150"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Categoria"/>
                <TextBox x:Name="txtCategoria" Width="100"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Precio (€)"/>
                <TextBox x:Name="txtPrecio" Width="100"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Cantidad vendida"/>
                <TextBox x:Name="txtVendido" Width="120"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Stock restante"/>
                <TextBox x:Name="txtStock" Width="120"/>
            </StackPanel>
            <Button Content="Agregar" Width="100" Margin="5" Click="BtnAgregar_Click"/>
            <Button Content="Informe" Width="100" Margin="5" Click="BtnInforme_Click"/>
            <StackPanel Orientation="Vertical">
                <Label Content="Filtracion categorias"></Label>
                <ComboBox x:Name="Combo_Categoria" SelectionChanged="Combo_Categoria_SelectionChanged">
                    <ComboBoxItem Content="perfume"></ComboBoxItem>
                    <ComboBoxItem Content="skincare"></ComboBoxItem>
                    <ComboBoxItem Content="maquillaje"></ComboBoxItem>
                    <ComboBoxItem Content="Bodycare"></ComboBoxItem>
                    <ComboBoxItem Content="Todos"></ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </StackPanel>


        <DataGrid x:Name="dgFrutas" Grid.Row="1" AutoGenerateColumns="False" ItemsSource="{Binding ListaProductos}" Margin="0,0,101,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Producto" Binding="{Binding producto}" Width="*"/>
                <DataGridTextColumn Header="Categoria" Binding="{Binding categoria}" Width="*"/>
                <DataGridTextColumn Header="Precio (€)" Binding="{Binding precio}" Width="*"/>
                <DataGridTextColumn Header="Vendido" Binding="{Binding vendido}" Width="*"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding stock}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
